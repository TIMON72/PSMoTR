{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "command": "${workspaceFolder}/build.bat",
            "type": "shell",
            "args": [
                "build",
                "${workspaceFolder}/PSMoTR/PSMoTR.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "problemMatcher": "$msCompile",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "options": {
                "shell": {
                    "executable": "cmd.exe",
                    "args": ["/c"]
                }
            }
        },
        {
            "label": "build-release",
            "command": "${workspaceFolder}/build.bat",
            "type": "shell",
            "args": [
                "build",
                "${workspaceFolder}/PSMoTR/PSMoTR.csproj",
                "-c",
                "Release",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "problemMatcher": "$msCompile",
            "options": {
                "shell": {
                    "executable": "cmd.exe",
                    "args": ["/c"]
                }
            }
        },
        {
            "label": "clean",
            "command": "${workspaceFolder}/build.bat",
            "type": "shell",
            "args": [
                "clean",
                "${workspaceFolder}/PSMoTR/PSMoTR.csproj"
            ],
            "problemMatcher": "$msCompile",
            "options": {
                "shell": {
                    "executable": "cmd.exe",
                    "args": ["/c"]
                }
            }
        },
        {
            "label": "test",
            "command": "${workspaceFolder}/build.bat",
            "type": "shell",
            "args": [
                "test",
                "${workspaceFolder}/PSMoTR_Tests/PSMoTR_Tests.csproj"
            ],
            "problemMatcher": "$msCompile",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "options": {
                "shell": {
                    "executable": "cmd.exe",
                    "args": ["/c"]
                }
            }
        }
    ]
}
